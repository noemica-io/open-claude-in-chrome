{
  "manifest_version": 3,
  "name": "Open Claude in Chrome",
  "version": "1.0.0",
  "description": "Claude in Chrome, open source. No domain blocklist. Any Chromium browser.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "debugger",
    "activeTab",
    "scripting",
    "nativeMessaging",
    "tabGroups",
    "windows",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
